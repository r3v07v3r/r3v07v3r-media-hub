{
  "name": "r3v07v3r-media-hub",
  "version": "0.24.0",
  "description": "Standalone TorBox-powered Movies, Series and Anime desktop client",
  "main": "src/main.cjs",
  "author": "R3v07v3R",
  "license": "UNLICENSED",
  "scripts": {
    "start": "electron .",
    "test": "node --test tests/*.test.cjs",
    "pack:win": "electron-builder --win nsis --x64 --publish never",
    "release:win": "electron-builder --win nsis --x64 --publish always"
  },
  "devDependencies": {
    "@electron/fuses": "^2.1.3",
    "electron": "^43.1.0",
    "electron-builder": "^26.0.12"
  },
  "dependencies": {
    "electron-updater": "^6.8.9"
  },
  "build": {
    "appId": "za.co.r3v07v3r.mediahub",
    "productName": "R3 Media Hub",
    "asar": true,
    "afterPack": "scripts/after-pack.cjs",
    "npmRebuild": false,
    "publish": [
      {
        "provider": "github",
        "owner": "R3v07v3R",
        "repo": "r3v07v3r-media-hub",
        "releaseType": "release"
      }
    ],
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "artifactName": "R3-Media-Hub-${version}-Setup.exe",
      "icon": "assets/app-icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "R3 Media Hub",
      "installerIcon": "assets/app-icon.ico",
      "uninstallerIcon": "assets/app-icon.ico"
    }
  }
}
