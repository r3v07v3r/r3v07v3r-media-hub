{
  "name": "r3v07v3r-media-hub",
  "version": "0.2.0",
  "description": "Standalone TorBox-powered Movies, Series and Anime desktop client",
  "main": "src/main.cjs",
  "author": "R3v07v3R",
  "license": "UNLICENSED",
  "scripts": {
    "start": "electron .",
    "test": "node --test tests/*.test.cjs",
    "pack:win": "electron-builder --win portable --x64"
  },
  "devDependencies": {
    "electron": "^37.2.0",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "za.co.r3v07v3r.mediahub",
    "productName": "R3V07V3R Media Hub",
    "asar": true,
    "directories": { "output": "dist" },
    "files": ["src/**/*", "package.json"],
    "win": { "target": ["portable"], "artifactName": "R3V07V3R-Media-Hub-${version}-Windows.exe" }
  }
}
